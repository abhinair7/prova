# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
MISTRAL_API_KEY=...
COHERE_API_KEY=...

# ── Vector Store ───────────────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=faiss          # faiss | chroma | pinecone
PINECONE_API_KEY=                   # only if backend=pinecone

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_BACKEND=disk                  # disk | redis | memory
REDIS_URL=redis://localhost:6379    # only if backend=redis

# ── Security ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-for-production

# ── Hardware ───────────────────────────────────────────────────────────────────
DEVICE=cpu                          # cpu | cuda | mps

# ── Observability ──────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
